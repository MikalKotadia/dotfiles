{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode-slim",
    "opencode-mermaid-renderer@0.0.3"
  ],
  "layout": "stretch",
  "autoupdate": true,
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "question": "allow"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    }
  },
  "provider": {
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  }
}
